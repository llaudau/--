{
    "version": 8,
    "configurePresets": [
        {
            "name": "GCC 13.3.0 x86_64-linux-gnu",
            "displayName": "GCC 13.3.0 x86_64-linux-gnu",
            "description": "Using compilers: C = /usr/bin/gcc, CXX = /usr/bin/g++",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "/usr/bin/gcc",
                "CMAKE_CXX_COMPILER": "/usr/bin/g++",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "GCC 15.2.0 aarch64-apple-darwin24",
            "displayName": "GCC 15.2.0 aarch64-apple-darwin24",
            "description": "Using compilers: C = /opt/homebrew/bin/aarch64-apple-darwin24-gcc-15, CXX = /opt/homebrew/bin/aarch64-apple-darwin24-g++-15",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "/opt/homebrew/bin/aarch64-apple-darwin24-gcc-15",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/bin/aarch64-apple-darwin24-g++-15",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}