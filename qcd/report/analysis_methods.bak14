	\begin{tabular}{|c|c|c|c|}
		\hline
		Method      & Update Type            & Parameters                     & Main Use Case              \\
		\hline
		APE         & Linear projection      & $\alpha$                       & Basic smoothing, fat links \\
		STOUT       & Exponential            & $\rho$                         & Topology, improved actions \\
		OvrImpSTOUT & Exponential            & $\rho, \epsilon$               & Topology, fast tunneling   \\
		HYP         & Multi-level projection & $\alpha_1, \alpha_2, \alpha_3$ & Quark smearing, cooling    \\
		Wilson Flow & Continuous flow        & $\epsilon$                     & Scale setting, topology    \\
		\hline
	\end{tabular}
\end{table}

